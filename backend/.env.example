GROQ_API_KEY=your_groq_api_key_here
PINECONE_API_KEY=your_pinecone_api_key_here

# The index is created automatically on first startup if it doesn't exist.
PINECONE_INDEX_NAME=research-portal

# Serverless index location — change if your Pinecone account uses a different region.
# Common values: aws/us-east-1, aws/us-west-2, gcp/us-central1, azure/eastus2
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
